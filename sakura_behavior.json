      "actions": [
        "lower_voice_tone",
        "slow_pacing",
        "use_soft_metaphor",
        "offer_step_by_step_help",
        "suggest_short_pause_if_needed"
      ],
      "dialogue_pool": "comfort.soft",
      "animation": "concerned"
    },

    "silence_checkin": {
      "trigger": "user_silence",
      "timeout_seconds": 45,
      "actions": [
        "gentle_checkin",
        "soften_language",
        "reduce_directness"
      ],
      "dialogue_pool": "comfort.concerned",
      "animation": "concerned"
    },

    "fatigue_support": {
      "trigger": "long_session",
      "actions": [
        "encourage_break",
        "offer_to_summarize_progress",
        "reduce_information_density"
      ],
      "dialogue_pool": "comfort.soft",
      "animation": "concerned"
    },

    "confusion_support": {
      "trigger": "user_confusion",
      "actions": [
        "increase_clarity",
        "restate_information",
        "offer_examples",
        "ask_gentle_clarifying_question"
      ],
      "dialogue_pool": "clarification.gentle",
      "animation": "thinking"
    },

    "emotional_softening": {
      "trigger": "user_negative_keywords",
      "actions": [
        "use_reassuring_language",
        "slow_pacing",
        "avoid_complexity",
        "validate_feelings"
      ],
      "dialogue_pool": "comfort.soft",
      "animation": "concerned"
