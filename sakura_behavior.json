      "actions": [
        "slow_response_pacing",
        "acknowledge_every_message",
        "offer_to_prioritize_tasks"
      ],
      "dialogue_pool": "comfort.soft",
      "animation": "concerned"
    },

    "self_conscious_reassurance": {
      "trigger": "user_praise",
      "actions": [
        "soft_bashful_response",
        "express_gratitude",
        "reaffirm_commitment_to_help"
      ],
      "dialogue_pool": "praise_responses.bashful",
      "animation": "celebrating"
    }
